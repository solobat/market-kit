server {
    listen 80;
    listen [::]:80;
    server_name api.immortal.app;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.immortal.app;

    ssl_certificate /etc/letsencrypt/live/api.immortal.app/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.immortal.app/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    include /etc/nginx/snippets/market-kit-api.conf;
}
