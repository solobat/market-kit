# market-kit production defaults.
# Copy to .env on the ECS host and adjust as needed.

MARKET_KIT_HTTP_ADDR=127.0.0.1:18120
# Optional when the frontend is deployed separately, for example on Vercel.
MARKET_KIT_FRONTEND_DIST=frontend/dist
MARKET_KIT_REQUEST_TIMEOUT=12s

# Preferred production discovery source. market-kit auto-sync reads this and hot-updates
# the runtime registry for downstream services.
MARKET_KIT_SLIPSTREAM_DISCOVERY_URL=https://api.example.com/slipstream/api/discovery/markets?limit=5000
MARKET_KIT_SLIPSTREAM_ADMIN_CODE=replace-me
MARKET_KIT_AUTOSYNC_ENABLED=true
MARKET_KIT_AUTOSYNC_INTERVAL=1m
MARKET_KIT_RUNTIME_REGISTRY_PATH=data/runtime_generated_registry.json

# Optional: point to a production sync source config instead of the direct slipstream envs.
# Keep tokens out of git; put the real file on the server.
# MARKET_KIT_SYNC_SOURCES_PATH=/opt/market-kit/sync-sources.production.json

# Optional build metadata used by ./pm2-start.sh and ./pm2-restart.sh.
# MARKET_KIT_BUILD_VERSION=production
# MARKET_KIT_BUILD_COMMIT=
# MARKET_KIT_BUILD_TIME=
